#!/usr/bin/env bash
# gemini-probe: shared helper for /gemini skill.
# Sourced from bash blocks; never execute directly.
#
# Functions:
#   gemini_auth_probe      — multi-signal auth check (env + file)
#   gemini_version_check   — warn on known-bad Gemini CLI versions
#   gemini_timeout_wrapper — gtimeout -> timeout -> unwrapped fallback
#
# Hygiene rules:
#   - Never set -e / set -u / trap / IFS= / PATH= in this file.
#   - All internal vars prefix with _GEMINI_.
#   - All functions prefix with gemini_.
#   - No command execution at source time (only function defs).

# --- Auth probe -------------------------------------------------------------

gemini_auth_probe() {
  local _gemini_home="${GEMINI_HOME:-$HOME/.gemini}"
  local _k1 _k2
  _k1=$(printf '%s' "${GOOGLE_API_KEY:-}" | tr -d '[:space:]')
  _k2=$(printf '%s' "${GEMINI_API_KEY:-}" | tr -d '[:space:]')
  if [ -n "$_k1" ] || [ -n "$_k2" ] || [ -f "$_gemini_home/auth.json" ] || [ -f "$HOME/.config/gemini/auth.json" ]; then
    echo "AUTH_OK"
    return 0
  fi
  echo "AUTH_FAILED"
  return 1
}

# --- Version check ----------------------------------------------------------

gemini_version_check() {
  local _ver
  _ver=$(gemini --version 2>/dev/null | head -1)
  [ -z "$_ver" ] && return 0
  # No known-bad versions yet; structure in place for future use.
  :
}

# --- Timeout wrapper --------------------------------------------------------

gemini_timeout_wrapper() {
  local _duration="$1"
  shift
  local _to
  _to=$(command -v gtimeout 2>/dev/null || command -v timeout 2>/dev/null || echo "")
  if [ -n "$_to" ]; then
    "$_to" "$_duration" "$@"
  else
    "$@"
  fi
}
